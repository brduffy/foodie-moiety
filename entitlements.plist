<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- HTTPS network access (community API, update checker, S3 downloads) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Microphone access (voice commands via Whisper) -->
    <key>com.apple.security.device.microphone</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- File picker dialogs (recipe/book import and export) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Required: CTranslate2 (faster-whisper) and onnxruntime (openwakeword)
         load native .dylib/.so at runtime. Hardened runtime blocks loading
         unsigned/ad-hoc-signed libraries without this entitlement.
         Can be removed if all bundled dylibs are individually codesigned. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
